---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
}

const { title, description, date, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={`/blog/${slug}`}
  class="group block rounded-[var(--radius-lg)] border border-border bg-background p-6 transition-colors hover:border-muted-foreground/40"
>
  <time class="text-sm text-muted-foreground">{formattedDate}</time>
  <h3 class="mt-2 text-(--text-h3) font-bold tracking-tight text-foreground group-hover:text-code-green transition-colors">
    {title}
  </h3>
  <p class="mt-2 text-muted-foreground leading-relaxed">
    {description}
  </p>
  <span class="mt-4 inline-block text-sm font-medium text-code-green">
    Read article &rarr;
  </span>
</a>
